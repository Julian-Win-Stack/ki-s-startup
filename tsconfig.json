{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "outDir": "dist",
    "rootDir": "src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "types": ["bun-types"],
    "paths": {
      "@receipt/core/*": ["./packages/core/src/*", "./packages/core/src/*.ts", "./packages/core/src/*.tsx"],
      "@receipt/core/*.js": ["./packages/core/src/*.ts", "./packages/core/src/*.tsx"]
    }
  },
  "references": [
    { "path": "./packages/core" }
  ],
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx"
  ]
}
